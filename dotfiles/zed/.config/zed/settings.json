{
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "ui_font_size": 16.0,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "tab_size": 2,
  "preferred_line_length": 120,
  "gutter": {
    "line_numbers": true,
  },
  "indent_guides": {
    "enabled": true,
  },
  "wrap_guides": [120],
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "languages": {
    "HTML": {
      "tab_size": 2,
      "prettier": {
        "allowed": true,
        "tabWidth": 2,
        "printWidth": 120,
      },
    },
  },
}
